# Build artefacts
build/
dist/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*.whl

# Debian build tree (generated by dpkg-buildpackage / dh)
debian/.debhelper/
debian/debhelper-build-stamp
debian/*.debhelper.log
debian/*.substvars
debian/files
debian/edit/           # staged package tree — gitignore needs the trailing slash
# Extra belt-and-suspenders: exclude all binary/generated package staging dirs
debian/*/DEBIAN/
debian/*/usr/
debian/*/etc/

# pybuild working directory
.pybuild/

# CMake in-source cache (should always use an out-of-source build dir)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CPackConfig.cmake
CPackSourceConfig.cmake
install_manifest.txt
*.deb
*.tar.gz

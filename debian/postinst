#!/bin/sh
# postinst — run after package installation
set -e

case "$1" in
    configure)
        # Ensure /opt/bin exists so the symlink installed by CMake is usable
        # immediately after dpkg unpacks the package.
        if [ ! -d /opt/bin ]; then
            mkdir -p /opt/bin
        fi

        # Attempt to create a 'zo' alias inside the package bin dir.
        # /opt/zopen/bin is not managed by any system package, so no
        # Breaks/Replaces stanza is needed.
        _edit_bin=/opt/zopen/bin/zopen
        _created=0
        for _dir in /opt/zopen/bin; do
            if [ ! -d "$_dir" ]; then
                continue
            fi
            _link="$_dir/zo"
            if [ -e "$_link" ] || [ -L "$_link" ]; then
                _target=$(readlink "$_link" 2>/dev/null || true)
                if [ "$_target" = "$_edit_bin" ] || [ "$_target" = "zopen" ]; then
                    _created=1
                    break
                else
                    echo "zopen: note: '$_link' already exists (→ ${_target:-regular file}); skipping alias in $_dir" >&2
                    continue
                fi
            fi

            # Shadowing check: warn if the system 'ed' is higher in PATH
            _sys_ed=$(command -v ed 2>/dev/null || true)
            if [ -n "$_sys_ed" ] && [ "$_sys_ed" != "$_link" ]; then
                echo "zopen: note: '$_sys_ed' exists; '$_link' may be shadowed if $_sys_ed's directory is earlier in PATH" >&2
            fi

            ln -sf zopen "$_link"
            echo "zopen: created alias: $_link → zopen"
            _created=1
            break
        done

        if [ "$_created" = "0" ]; then
            echo "zopen: could not create 'zo' alias automatically." >&2
            echo "zopen: run 'zopen --install-alias' as the target user to create it." >&2
        fi
        ;;
esac

#DEBHELPER#

exit 0

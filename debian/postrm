#!/bin/sh
# postrm — run after package removal
set -e

case "$1" in
    purge)
        # Remove the config directory only on full purge
        if [ -d /opt/etc/zopen ]; then
            rm -rf /opt/etc/zopen
        fi
        ;;
    remove)
        # Remove the convenience symlinks we may have created.
        # Only remove if they still point to our binary.
        _zedit_bin=/opt/zopen/bin/zopen
        for _link in /opt/bin/zopen /usr/local/bin/zopen; do
            if [ -L "$_link" ]; then
                _target=$(readlink "$_link" 2>/dev/null || true)
                if [ "$_target" = "$_zedit_bin" ]; then
                    rm -f "$_link"
                    echo "zopen: removed symlink: $_link"
                fi
            fi
        done
        ;;
esac

#DEBHELPER#

exit 0
